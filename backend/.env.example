# Copy to .env and fill in real values

CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key...
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
FRONTEND_URL=https://your-netlify-domain.netlify.app

# Optional: set to true to allow all CORS origins (useful for dev, never for prod)
ALLOW_ALL_ORIGINS=false

# Dodo Payments (optional — set to "skip" to disable)
DODO_API_KEY=skip
DODO_WEBHOOK_SECRET=skip
DODO_PRODUCT_ID=skip
# Set to true to hit Dodo sandbox instead of live API
DODO_TEST_MODE=true

# Optional: override JWKS URL (auto-derived from CLERK_PUBLISHABLE_KEY if not set)
# CLERK_JWKS_URL=https://your-clerk-domain/.well-known/jwks.json
